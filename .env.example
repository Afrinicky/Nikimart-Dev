# Database — PostgreSQL. Use any hosted Postgres (Vercel Postgres, Neon,
# Supabase, Railway, …). Format:
#   postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public&sslmode=require
# For local development you can run Postgres locally, e.g.:
#   postgresql://postgres:postgres@127.0.0.1:5432/nikimart?schema=public
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/nikimart?schema=public"

# Auth.js secret — REQUIRED in every environment (including Vercel).
# Generate with: npx auth secret   (or `openssl rand -base64 32`)
AUTH_SECRET="replace-me-with-a-long-random-string"

# Needed when running behind a proxy / non-localhost host.
AUTH_TRUST_HOST=true
