# Database — SQLite for local dev. For production use a hosted Postgres URL
# and change the datasource provider in prisma/schema.prisma to "postgresql".
DATABASE_URL="file:./dev.db"

# Auth.js secret — generate with: npx auth secret  (or `openssl rand -base64 32`)
AUTH_SECRET="replace-me-with-a-long-random-string"

# Needed when running behind a proxy / non-localhost host in dev.
AUTH_TRUST_HOST=true
